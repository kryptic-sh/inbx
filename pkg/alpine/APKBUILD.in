#
# Auto-generated. Source: https://github.com/kryptic-sh/inbx
# Edits made directly to a built .apk are not tracked. To change this
# APKBUILD, edit `pkg/alpine/APKBUILD.in` in the upstream repo and let
# `.github/workflows/release.yml` rebuild on the next tag.
pkgname=inbx
pkgver={VERSION}
pkgrel=0
pkgdesc="inbx — modal-vim email client"
url="https://inbx.kryptic.sh/"
arch="x86_64"
license="MIT"
# !check  — no test suite shipped in the binary tarball.
# !strip  — binary is already stripped by the upstream release build,
#           and abuild's strip step rejects cross-built artifacts.
options="!check !strip"
source="inbx-v$pkgver-x86_64-unknown-linux-musl.tar.gz::https://github.com/kryptic-sh/inbx/releases/download/v$pkgver/inbx-v$pkgver-x86_64-unknown-linux-musl.tar.gz"

package() {
    install -Dm755 "$srcdir/inbx" "$pkgdir/usr/bin/inbx"
    install -Dm755 "$srcdir/inbx-sync" "$pkgdir/usr/bin/inbx-sync"
    install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "$srcdir/README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}

sha512sums="{SHA512_X86_64}  inbx-v$pkgver-x86_64-unknown-linux-musl.tar.gz"
